generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  artist
  curator
  both
  admin
}

enum CuratorProfileStatus {
  pending
  active
  suspended
  revoked
}

enum CuratorStatusTrigger {
  manual
  automated
}

enum CuratorApplicationStatus {
  pending
  approved
  rejected
}

enum SpotifyCheckStatus {
  passed
  failed_threshold
  failed_private
  failed_api_error
  failed_ownership
}

// ─── Core user ───────────────────────────────────────────────────────────────

model User {
  id                    String                 @id @default(cuid())
  clerkId               String                 @unique
  // Role is never manually set — it is always a consequence of application status.
  // artist (default) → both (on curator application approval). admin is separate.
  role                  UserRole               @default(artist)
  credits               Int                    @default(10)
  // Reputation foundation — updated after each completed session
  trustScore            Float                  @default(1.0)
  tracks                Track[]
  sessions              ListeningSession[]
  listenEvents          ListenEvent[]
  spotifyAccount        SpotifyAccount?
  playlists             Playlist[]
  playlistSnapshots     PlaylistSnapshot[]
  playlistVerifications PlaylistVerification[]
  artistProfile         ArtistProfile?
  curatorProfile        CuratorProfile?
  curatorApplications   CuratorApplication[]
  reviewedApplications  CuratorApplication[]   @relation("ApplicationReviewer")
  triggeredStatusEvents CuratorStatusEvent[]   @relation("StatusEventTrigger")
  platformSettings      PlatformSetting[]      @relation("SettingUpdater")
}

model Track {
  id                    String                 @id @default(cuid())
  userId                String
  spotifyUrl            String
  spotifyTrackId        String?
  title                 String?
  artistName            String?
  artworkUrl            String?
  createdAt             DateTime               @default(now())
  // Extended submission metadata — auto-pulled from Spotify on submit
  releasedAt            DateTime?
  durationMs            Int?
  bpm                   Float?
  explicit              Boolean?
  // Artist-selected form fields
  genres                String[]               @default([])
  moods                 String[]               @default([])
  soundsLikeArtists     Json?
  story                 String?
  targetRegion          String?
  user                  User                   @relation(fields: [userId], references: [id])
  // Cascade: deleting a track removes all its sessions (and their ratings)
  sessions              ListeningSession[]     @relation("TrackSessions")
  playlistSnapshots     PlaylistSnapshot[]
  playlistVerifications PlaylistVerification[]

  @@index([spotifyTrackId])
}

model ListeningSession {
  id                 String         @id @default(cuid())
  userId             String
  trackId            String
  startedAt          DateTime       @default(now())
  activeListenTimeMs Int            @default(0)
  completed          Boolean        @default(false)
  isCuratorReview    Boolean        @default(false)
  playlistAdded      Boolean        @default(false)
  user               User           @relation(fields: [userId], references: [id])
  track              Track          @relation("TrackSessions", fields: [trackId], references: [id], onDelete: Cascade)
  rating             Rating?
  listenEvent        ListenEvent?
  curatorReview      CuratorReview?

  @@unique([userId, trackId])
}

// Behavioral log â€" one record per session, written atomically with rating
// Powers anti-gaming detection and future reputation scoring
model ListenEvent {
  id               String           @id @default(cuid())
  sessionId        String           @unique
  userId           String
  resetsCount      Int              @default(0)
  listenDurationMs Int              @default(0)
  timeToVibeMs     Int?
  createdAt        DateTime         @default(now())
  // Cascade with session
  session          ListeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Rating {
  id        String           @id @default(cuid())
  sessionId String           @unique
  score     Int
  vibe      String?
  createdAt DateTime         @default(now())
  // Cascade: deleting a session removes its rating
  session   ListeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// Rich feedback left by an approved curator on a curator review session.
// Separate from Rating (which is the artist listen economy rating).
model CuratorReview {
  id               String           @id @default(cuid())
  sessionId        String           @unique
  productionScore  Int              // 1-5
  genreFitScore    Int              // 1-5
  overallScore     Int              // 1-5 — the score shown to the artist
  notes            String?          // "What would you tell this artist?"
  playlistDecision Boolean          // true = add to playlist, false = not this time
  createdAt        DateTime         @default(now())
  session          ListeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SpotifyAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  spotifyUserId String   @unique
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Playlist {
  id                String                 @id @default(cuid())
  userId            String
  spotifyPlaylistId String
  spotifyUrl        String?
  name              String
  followers         Int                    @default(0)
  trackCount        Int                    @default(0)
  lastSyncedAt      DateTime
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots         PlaylistSnapshot[]
  verifications     PlaylistVerification[]

  @@unique([userId, spotifyPlaylistId])
  @@index([userId, lastSyncedAt])
}

enum PlaylistSnapshotType {
  before
}

model PlaylistSnapshot {
  id            String                 @id @default(cuid())
  userId        String
  playlistId    String
  trackId       String
  snapshotType  PlaylistSnapshotType   @default(before)
  trackIds      Json
  trackEntries  Json?
  createdAt     DateTime               @default(now())
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist      Playlist               @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track         Track                  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  verifications PlaylistVerification[]

  @@index([userId, trackId, createdAt])
  @@index([playlistId, createdAt])
}

enum PlaylistVerificationQuality {
  pending
  verified
  failed
  low_quality
}

enum PlaylistVerificationType {
  snapshot
  platform
}

model PlaylistVerification {
  id                   String                      @id @default(cuid())
  userId               String
  trackId              String
  playlistId           String
  snapshotId           String?
  verificationType     PlaylistVerificationType    @default(snapshot)
  verified             Boolean                     @default(false)
  quality              PlaylistVerificationQuality @default(pending)
  currentTrackPosition Int?
  verifiedAt           DateTime?
  lastCheckedAt        DateTime?
  persistenceDueAt     DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  user                 User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  track                Track                       @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlist             Playlist                    @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  snapshot             PlaylistSnapshot?           @relation(fields: [snapshotId], references: [id], onDelete: SetNull)

  @@unique([userId, trackId])
  @@index([playlistId, verified])
  @@index([persistenceDueAt])
}

// ─── Persona profiles ────────────────────────────────────────────────────────

// Created automatically on registration. Every user is an artist by default.
model ArtistProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Created only when a CuratorApplication is approved (in the same transaction
// that updates users.role to 'both'). Never created manually.
model CuratorProfile {
  id           String               @id @default(cuid())
  userId       String               @unique
  displayName  String?
  bio          String?
  // active → suspended (temporary, reinstatable) → revoked (permanent)
  // Suspension is enforced here, NOT via users.role. Role stays 'both'.
  status       CuratorProfileStatus @default(active)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlists    CuratorPlaylist[]
  statusEvents CuratorStatusEvent[]
  // The single approved application that created this profile
  approvedFrom CuratorApplication?
}

// One row per curator-owned/collaborative playlist.
// Created in the approval transaction, one per passing CuratorApplicationPlaylist.
// genres[] here is the canonical source for the matching algorithm.
model CuratorPlaylist {
  id                String         @id @default(cuid())
  curatorProfileId  String
  spotifyPlaylistId String
  playlistName      String
  followers         Int            @default(0)
  genres            String[]       @default([])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  curatorProfile    CuratorProfile @relation(fields: [curatorProfileId], references: [id], onDelete: Cascade)

  @@unique([curatorProfileId, spotifyPlaylistId])
  @@index([curatorProfileId])
}

// ─── Curator application flow ────────────────────────────────────────────────

// Progression: artist (Spotify connected) → submit application with 1-10 playlists
// → per-playlist: ownership + follower check (inline, before submission)
// → playlists that pass enter admin review queue
// → admin approves/rejects whole application
// → approved: CuratorProfile + CuratorPlaylist rows created + role: both
model CuratorApplication {
  id               String                      @id @default(cuid())
  userId           String
  status           CuratorApplicationStatus    @default(pending)
  rejectionReason  String?
  // Set on approval in the same tx that creates CuratorProfile
  curatorProfileId String?                     @unique
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  user             User                        @relation(fields: [userId], references: [id])
  playlists        CuratorApplicationPlaylist[]
  curatorProfile   CuratorProfile?             @relation(fields: [curatorProfileId], references: [id], onDelete: SetNull)
  reviewer         User?                       @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId, status])
}

// One row per submitted playlist. Checks run per-playlist at submission time.
// Only rows with spotifyCheckStatus = 'passed' appear in the admin review queue.
model CuratorApplicationPlaylist {
  id                   String              @id @default(cuid())
  applicationId        String
  spotifyPlaylistId    String
  playlistName         String?
  followerCountAtApply Int?
  thresholdMet         Boolean?
  // passed | failed_threshold | failed_private | failed_api_error | failed_ownership
  spotifyCheckStatus   SpotifyCheckStatus?
  genres               String[]            @default([])
  createdAt            DateTime            @default(now())
  application          CuratorApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, spotifyPlaylistId])
  @@index([applicationId, spotifyCheckStatus])
}

// Full audit trail of every CuratorProfile status change.
// triggered_by is null for automated suspensions (no human actor).
model CuratorStatusEvent {
  id               String               @id @default(cuid())
  curatorProfileId String
  fromStatus       CuratorProfileStatus
  toStatus         CuratorProfileStatus
  triggerType      CuratorStatusTrigger
  triggeredBy      String?
  reason           String
  createdAt        DateTime             @default(now())
  curatorProfile   CuratorProfile       @relation(fields: [curatorProfileId], references: [id], onDelete: Cascade)
  triggeredByUser  User?                @relation("StatusEventTrigger", fields: [triggeredBy], references: [id], onDelete: SetNull)

  @@index([curatorProfileId, createdAt])
}

// ─── Platform configuration ───────────────────────────────────────────────────

// Key-value store for runtime-adjustable platform constants.
// Seed on first deploy: curator_min_followers = '500'
// Cache reads for 60 minutes — changes propagate within the hour, no redeploy needed.
// updatedBy is nullable to allow system-seeded values with no human actor.
model PlatformSetting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
  updater   User?    @relation("SettingUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
}
